{
  "name": "flamingo",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "api",
    "web",
    "e2e"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently --names \"api,web\" --prefix-colors \"cyan,magenta\" \"npm run api\" \"npm run web\"",
    "api": "npm run start:dev --workspace=api",
    "web": "npm run dev --workspace=web",
    "api:build": "npm run build --workspace=api",
    "web:build": "npm run build --workspace=web",
    "test:e2e": "npm run test --workspace=e2e",
    "test:e2e:web": "npm run test:web --workspace=e2e",
    "test:e2e:admin": "npm run test:admin --workspace=e2e",
    "snyk:test": "snyk test --all-projects --severity-threshold=high",
    "snyk:monitor": "snyk monitor --all-projects --org=flamingo"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "snyk": "^1.1305.1"
  },
  "lint-staged": {
    "api/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "api/test/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "web/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}

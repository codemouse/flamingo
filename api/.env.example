# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=flamingo

# ── Plaid ──────────────────────────────────────────────────────────────────
# Environment: sandbox | production
PLAID_ENV=sandbox

# Credentials from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=
PLAID_SECRET=

# Optional: webhook URL receiving Plaid events (SYNC_UPDATES_AVAILABLE, etc.)
PLAID_WEBHOOK_URL=

# Comma-separated products requested at link time
# (transactions,auth,identity,liabilities,investments,assets,income_verification,signal,transfer,statements,...)
PLAID_PRODUCTS=transactions

# Comma-separated country codes (US,CA,GB,IE,FR,ES,NL,DE,IT,PL,DK,NO,SE,EE,LT,LV,BE)
PLAID_COUNTRY_CODES=US

# Link UI language (en, fr, es, nl, de, it, pl, da, no, sv, et, lt, lv)
PLAID_LANGUAGE=en

# Comma-separated institution IDs for the sandbox pool feature
# (only used when PLAID_ENV=sandbox)
PLAID_SANDBOX_INSTITUTIONS=ins_109508,ins_127989,ins_43

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d
